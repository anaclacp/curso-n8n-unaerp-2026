        "jsCode": "// Falta info - usa resposta provisória do extrator\nconst booking = $('Parse Booking').first().json.booking;\nconst phone = $('Parse Booking').first().json.phone;\n\nreturn [{\n  json: {\n    phone,\n    resposta: booking.resposta_provisoria || 'Pode me dizer qual serviço, dia e horário você quer?'\n  }\n}];"
