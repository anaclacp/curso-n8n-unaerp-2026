      "id": "652b8f95-f63c-4676-afea-bdf4516fb27c",
      "name": "Buscar Histórico (MongoDB)",
      "type": "n8n-nodes-base.mongoDb",
      "typeVersion": 1.1,
      "position": [
        -1232,
