      "parameters": {
        "jsCode": "// Parse extração e decide próximo passo\nconst response = $input.first().json;\nconst content = response.choices[0].message.content;\nconst extracted = JSON.parse(content);\n\nconst contextData = $('Parse Intenção').first().json;\n\n// Mapeia duração\nconst duracoes = {\n  corte: 40,\n  corte_barba: 60,\n  barba: 30,\n  pezinho: 15,\n  sobrancelha: 15\n};\n\nconst duracao = duracoes[extracted.servico] || 40;\n\nreturn [{\n  json: {\n    ...contextData,\n    booking: extracted,\n    duracaoMin: duracao,\n    completo: extracted.falta && extracted.falta.length === 0 && extracted.acao === 'MARCAR'\n  }\n}];"
      },
