      "parameters": {
        "jsCode": "// Resposta de saudação\nconst data = $input.first().json;\nconst nome = data.pushName || 'tudo bem';\n\nconst mensagem = `Olá, ${nome}! 💈\\n\\nSou o assistente da Barbearia Estilo. Posso te ajudar com:\\n• Agendamento de horário\\n• Informações de preços e serviços\\n• Horário de funcionamento\\n\\nO que você precisa?`;\n\nreturn [{\n  json: {\n    phone: data.phone,\n    resposta: mensagem\n  }\n}];"
      },
