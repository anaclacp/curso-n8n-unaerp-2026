    {
      "parameters": {
        "jsCode": "// Conflito - sugere alternativas\nconst booking = $('Checar Conflito').first().json.booking;\nconst phone = $('Checar Conflito').first().json.phone;\n\nconst mensagem = `Ops! O horário de ${booking.hora} no dia ${booking.data} já está ocupado. 😬\\n\\nMe diga outro horário que prefere e eu confiro a disponibilidade!`;\n\nreturn [{\n  json: {\n    phone,\n    resposta: mensagem\n  }\n}];"
      },
