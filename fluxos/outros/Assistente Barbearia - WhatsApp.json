    {
      "parameters": {
        "jsCode": "// Gera mensagem de confirmação\nconst booking = $('Parse Booking').first().json.booking;\nconst phone = $('Parse Booking').first().json.phone;\n\nconst servicosNome = {\n  corte: 'Corte',\n  corte_barba: 'Corte + Barba',\n  barba: 'Barba',\n  pezinho: 'Pezinho',\n  sobrancelha: 'Sobrancelha'\n};\n\nconst dataObj = new Date(`${booking.data}T${booking.hora}:00-03:00`);\nconst dataFmt = dataObj.toLocaleDateString('pt-BR', { weekday: 'long', day: '2-digit', month: '2-digit' });\n\nconst mensagem = `✅ Agendamento confirmado!\\n\\n📅 ${dataFmt}\\n⏰ ${booking.hora}\\n💈 ${servicosNome[booking.servico]}\\n👤 ${booking.nome || 'Cliente'}\\n\\nTe esperamos! Se precisar remarcar, é só me chamar.`;\n\nreturn [{\n  json: {\n    phone,\n    resposta: mensagem\n  }\n}];"
      },
      "id": "45128551-74b2-48df-b9d4-48eb04902e0f",
