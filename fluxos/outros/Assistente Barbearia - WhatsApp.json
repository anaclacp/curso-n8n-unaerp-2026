    {
      "parameters": {
        "jsCode": "// Verifica se há conflito de horário\nconst events = $input.all();\nconst booking = $('Parse Booking').first().json.booking;\nconst duracao = $('Parse Booking').first().json.duracaoMin;\n\nconst dataHoraInicio = new Date(`${booking.data}T${booking.hora}:00-03:00`);\nconst dataHoraFim = new Date(dataHoraInicio.getTime() + duracao * 60000);\n\nlet conflito = false;\nfor (const item of events) {\n  if (!item.json.start) continue;\n  const eventStart = new Date(item.json.start.dateTime || item.json.start.date);\n  const eventEnd = new Date(item.json.end.dateTime || item.json.end.date);\n  \n  // Sobreposição\n  if (dataHoraInicio < eventEnd && dataHoraFim > eventStart) {\n    conflito = true;\n    break;\n  }\n}\n\nconst contextData = $('Parse Booking').first().json;\n\nreturn [{\n  json: {\n    ...contextData,\n    conflito,\n    dataHoraInicio: dataHoraInicio.toISOString(),\n    dataHoraFim: dataHoraFim.toISOString()\n  }\n}];"
      },
