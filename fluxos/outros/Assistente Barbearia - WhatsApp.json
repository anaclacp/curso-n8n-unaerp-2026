    {
      "parameters": {
        "jsCode": "// Extrai e normaliza dados da mensagem do Evolution API\nconst body = $input.first().json.body;\n\n// Ignora mensagens enviadas pela própria barbearia (fromMe)\nif (body.data?.key?.fromMe === true) {\n  return [];\n}\n\nconst remoteJid = body.data?.key?.remoteJid || '';\nconst phone = remoteJid.replace('@s.whatsapp.net', '');\n\n// Suporta texto, áudio (transcrição via OpenAI depois) e imagem\nconst message = body.data?.message || {};\nconst text = message.conversation \n  || message.extendedTextMessage?.text \n  || '';\n\nconst pushName = body.data?.pushName || 'Cliente';\nconst messageId = body.data?.key?.id;\nconst instance = body.instance;\n\nif (!text || !phone) {\n  return [];\n}\n\nreturn [{\n  json: {\n    phone,\n    text: text.trim(),\n    pushName,\n    messageId,\n    instance,\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
      "id": "489bb8bf-0bb6-4ad2-a606-34836e30fc04",
      "name": "Normalizar Input",
      "type": "n8n-nodes-base.code",
