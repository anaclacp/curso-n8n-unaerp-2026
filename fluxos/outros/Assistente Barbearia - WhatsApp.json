    {
      "parameters": {
        "jsCode": "// Monta o histórico para enviar ao classificador\nconst input = $('Normalizar Input').first().json;\nconst historyDoc = $input.first().json;\n\nconst history = historyDoc?.messages || [];\n\n// Limita às últimas 10 mensagens para economia de tokens\nconst recentHistory = history.slice(-10);\n\nreturn [{\n  json: {\n    ...input,\n    history: recentHistory,\n    historyText: recentHistory\n      .map(m => `${m.role === 'user' ? 'Cliente' : 'Assistente'}: ${m.content}`)\n      .join('\\n')\n  }\n}];"
      },
      "id": "8eb25987-73d9-4b57-9afa-d9d9b7708255",
      "name": "Montar Contexto",
      "type": "n8n-nodes-base.code",
